# Kopiere diese Datei zu ".env" und trage deine echten Werte ein.
# .env wird NICHT eingecheckt (siehe .gitignore).
#
# Lokal kannst du diese Variablen vor dem Start setzen, z. B.:
#   export $(grep -v '^#' .env | xargs)   &&   mvn spring-boot:run

# --- Supabase PostgreSQL (Session-Pooler-Verbindung, IPv4 + SSL) ---
# Findest du in Supabase: Project Settings -> Database -> Connection string -> "Session pooler".
# Wandle sie ins JDBC-Format um (jdbc:postgresql://HOST:PORT/postgres?sslmode=require).
SPRING_DATASOURCE_URL=jdbc:postgresql://aws-0-eu-central-1.pooler.supabase.com:5432/postgres?sslmode=require
SPRING_DATASOURCE_USERNAME=postgres.pxeejfowdivavcqbigsc
SPRING_DATASOURCE_PASSWORD=DEIN_DB_PASSWORT

# --- JWT-Schlüssel: irgendein langer, zufälliger, geheimer Text (>= 32 Zeichen) ---
APP_JWT_SECRET=bitte-hier-einen-langen-zufaelligen-geheimen-schluessel-eintragen-min-32

# --- Optional ---
# APP_JWT_EXPIRATION_MS=2592000000
# APP_CORS_ALLOWED_ORIGINS=https://alibrb666.github.io,http://localhost:5500
